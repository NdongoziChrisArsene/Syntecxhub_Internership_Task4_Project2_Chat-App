<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for Firebase to connect to the internet -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for reading images from gallery (profile picture upload) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="ChatApp"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <!--
            LoginActivity is the LAUNCHER — the first screen the user sees.
            If a user is already logged in, LoginActivity immediately redirects
            them to MainActivity (see LoginActivity.onStart()).
        -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Sign-up / registration screen -->
        <activity android:name=".SignupActivity" />

        <!-- Main chat list screen (shown after login) -->
        <activity android:name=".MainActivity" />

        <!-- Individual chat conversation screen -->
        <activity android:name=".ChatActivity" />

    </application>

</manifest>
